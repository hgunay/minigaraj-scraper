# ============================================================================
# MiniGaraj Scraper - Environment Variables
# Copy to .env and adjust values for your environment
# ============================================================================

# App
SCRAPER_APP_ENV=development
SCRAPER_APP_PORT=8300
SCRAPER_APP_API_KEY=          # empty = auth disabled (dev mode)

# Database — app user
SCRAPER_DB_HOST=localhost
SCRAPER_DB_PORT=5433
SCRAPER_DB_USER=scraper
SCRAPER_DB_PASSWORD=scraper
SCRAPER_DB_NAME=minigaraj_scraper
SCRAPER_DB_SSLMODE=disable
SCRAPER_DB_MAX_OPEN_CONNS=10
SCRAPER_DB_MAX_IDLE_CONNS=5
SCRAPER_DB_MAX_LIFETIME_MINUTES=30

# Database — admin user (for auto-create DB + migrations)
SCRAPER_DB_INIT_USER=postgres
SCRAPER_DB_INIT_USER_PASSWORD=postgres

# Crawler
SCRAPER_CRAWLER_PARALLELISM=4
SCRAPER_CRAWLER_REQUEST_DELAY_MS=1000
SCRAPER_CRAWLER_RANDOM_DELAY_MS=500
SCRAPER_CRAWLER_MAX_DEPTH=5
SCRAPER_CRAWLER_TIMEOUT_SEC=30
SCRAPER_CRAWLER_MAX_RETRIES=3

# Logging
SCRAPER_LOG_LEVEL=info        # debug, info, warn, error
SCRAPER_LOG_FORMAT=console    # console, json
